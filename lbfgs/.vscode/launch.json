{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug fwi_lbfgs (cuda-gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/fwi_lbfgs",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "CUDA_LAUNCH_BLOCKING",
          "value": "1"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/opt/nvidia/hpc_sdk/Linux_x86_64/24.5/compilers/bin/cuda-gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Debug fwi_lbfgs (gdb fallback)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/fwi_lbfgs",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
